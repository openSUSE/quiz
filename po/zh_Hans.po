msgid "Welcome, %s"
msgstr "欢迎，%s"

msgid "Are you sure you want to quit and submit?"
msgstr "确定要退出并提交吗？"

msgid "Username is too short."
msgstr "用户名太短"

msgid "Sorry, this login is already taken."
msgstr "抱歉，此登录名已被占用。"

msgid "Are you sure you want to quit? Your progress will not be saved."
msgstr "确定要退出吗？你的进度将不会被保存。"

msgid "Use a recognizable nickname, like ZypperJedi, or preferably your real name (NameSurname)."
msgstr "使用易于识别的昵称，例如 ZypperJedi，或最好使用你的真实姓名。"
